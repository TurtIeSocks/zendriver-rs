---
source: crates/zendriver-mcp/tests/schema_snapshots.rs
expression: "schema_for! (tools::lifecycle::OpenInput)"
---
$schema: "https://json-schema.org/draft/2020-12/schema"
title: OpenInput
description: "Input for `browser_open`."
type: object
properties:
  block_trackers:
    description: "Enable the bundled curated tracker/fingerprinter blocklist (passive\nthird-party fingerprinters + cross-site trackers; excludes anti-bot\nchallenge vendors). Off by default."
    type:
      - boolean
      - "null"
  headless:
    description: "Run Chrome with `--headless=new` (default: `true`)."
    type: boolean
    default: true
  persona:
    description: "A fingerprint Persona JSON (as produced by `browser_fingerprint_generate`\nor hand-built). Parsed via `Persona::try_from_json`. Opaque on the wire."
  preferences:
    description: "Chrome profile preferences merged into `Default/Preferences` at launch\n(dotted keys → nested objects). See `BrowserBuilder::preference`."
    type:
      - object
      - "null"
    additionalProperties: true
  stealth_profile:
    description: "Override the session's default stealth profile for this launch.\nWhen `None`, the session-wide default (set via CLI / construct time)\nis used."
    anyOf:
      - $ref: "#/$defs/StealthProfileChoice"
      - type: "null"
    default: ~
  tracker_blocklist:
    description: "Custom tracker-blocklist source (url | file | inline domains). Supplying\nthis implicitly enables blocking; combine with `block_trackers: true`\nto also include the bundled list."
    anyOf:
      - $ref: "#/$defs/TrackerBlocklist"
      - type: "null"
additionalProperties: false
$defs:
  StealthProfileChoice:
    description: "Stealth profile choice carried over the MCP wire.\n\nConcrete `StealthProfile` resolution happens inside the lifecycle\nhandler (it depends on platform detection that only matters at launch\ntime); the wire-level enum stays stable and platform-agnostic."
    oneOf:
      - description: "Defer to `zendriver_stealth::StealthProfile::native()` (auto-detect\nplatform via `sysinfo`)."
        type: string
        const: auto
      - description: "Force native (same as `Auto`, but explicit)."
        type: string
        const: native
      - description: Spoof a macOS fingerprint regardless of host platform.
        type: string
        const: spoof_macos
      - description: Spoof a Linux fingerprint regardless of host platform.
        type: string
        const: spoof_linux
      - description: Spoof a Windows fingerprint regardless of host platform.
        type: string
        const: spoof_windows
  TrackerBlocklist:
    description: "A custom tracker-blocklist source for `browser_open`.\n\nOne of: a remote `url` (fetched+cached at launch), a local `file` path, or\ninline `domains`. Supplying any source implicitly enables blocking."
    oneOf:
      - description: Fetch + cache a newline-delimited host list from this URL.
        type: object
        properties:
          source:
            type: string
            const: url
          url:
            type: string
        additionalProperties: false
        required:
          - source
          - url
      - description: Read a newline-delimited host list from this local file path.
        type: object
        properties:
          path:
            type: string
          source:
            type: string
            const: file
        additionalProperties: false
        required:
          - source
          - path
      - description: Block these hostnames directly.
        type: object
        properties:
          domains:
            type: array
            items:
              type: string
          source:
            type: string
            const: domains
        additionalProperties: false
        required:
          - source
          - domains
