---
source: crates/zendriver-mcp/tests/schema_snapshots.rs
expression: "schema_for! (tools::lifecycle::OpenInput)"
---
$schema: "https://json-schema.org/draft/2020-12/schema"
title: OpenInput
description: "Input for `browser_open`."
type: object
properties:
  block_trackers:
    description: "Enable the bundled curated tracker/fingerprinter blocklist (passive\nthird-party fingerprinters + cross-site trackers; excludes anti-bot\nchallenge vendors). Off by default."
    type:
      - boolean
      - "null"
  geo_auto:
    description: "Auto-derive `locale`/`languages`/`timezone` from the exit IP via a\nproxied probe to an IP-geolocation service (default `ip-api.com`).\nOpt-in; makes at most ONE outbound HTTP request, at launch, and only\nwhen this is `true`. Mirrors `proxy` above when both are set, so the\nprobe reports the same exit IP Chrome will actually use. The resolved\ntimezone is the EXACT IANA zone the probe reports for the exit IP\n(not a country-representative one), so multi-timezone countries (US,\nRU, CA, AU, BR, ...) get the visitor's real local zone. Overridden by\nan explicit `persona`/locale, which also skips the probe. Always\npresent in the schema so the wire shape is feature-stable; only takes\neffect when the server is built with the `geo` feature (otherwise\nignored — a warning is logged)."
    type: boolean
    default: false
  geo_endpoint:
    description: "Override the geo-probe endpoint (default `http://ip-api.com/json`).\nOnly meaningful together with `geo_auto: true`; ignored otherwise.\nSame feature gating as `geo_auto`. Note: this bypasses proxy\nmirroring — the probe against a custom endpoint is NOT routed through\n`proxy` above (the underlying `IpApiResolver::with_proxy` wiring is\ncrate-private to `zendriver`); only the bundled default endpoint gets\nproxy mirroring."
    type:
      - string
      - "null"
  headless:
    description: "Run Chrome with `--headless=new` (default: `true`)."
    type: boolean
    default: true
  persona:
    description: "A fingerprint Persona JSON (as produced by `browser_fingerprint_generate`\nor hand-built). Parsed via `Persona::try_from_json`. Opaque on the wire."
  preferences:
    description: "Chrome profile preferences merged into `Default/Preferences` at launch\n(dotted keys → nested objects). See `BrowserBuilder::preference`."
    type:
      - object
      - "null"
    additionalProperties: true
  proxy:
    description: "Route the browser through an upstream proxy\n(`scheme://[user:pass@]host:port`). Userinfo is auto-split into proxy\nauth credentials and answered via the `Fetch.authRequired` handshake\n(requires the `interception` feature — without it the credentials are\nsimply not auto-wired). See `BrowserBuilder::proxy`."
    type:
      - string
      - "null"
  stealth_profile:
    description: "Override the session's default stealth profile for this launch.\nWhen `None`, the session-wide default (set via CLI / construct time)\nis used."
    anyOf:
      - $ref: "#/$defs/StealthProfileChoice"
      - type: "null"
    default: ~
  tracker_blocklist:
    description: "Custom tracker-blocklist source (url | file | inline domains). Supplying\nthis implicitly enables blocking; combine with `block_trackers: true`\nto also include the bundled list."
    anyOf:
      - $ref: "#/$defs/TrackerBlocklist"
      - type: "null"
additionalProperties: false
$defs:
  StealthProfileChoice:
    description: "Stealth profile choice carried over the MCP wire.\n\nConcrete `StealthProfile` resolution happens inside the lifecycle\nhandler (it depends on platform detection that only matters at launch\ntime); the wire-level enum stays stable and platform-agnostic."
    oneOf:
      - description: "Defer to `zendriver_stealth::StealthProfile::native()` (auto-detect\nplatform via `sysinfo`)."
        type: string
        const: auto
      - description: "Force native (same as `Auto`, but explicit)."
        type: string
        const: native
      - description: Spoof a macOS fingerprint regardless of host platform.
        type: string
        const: spoof_macos
      - description: Spoof a Linux fingerprint regardless of host platform.
        type: string
        const: spoof_linux
      - description: Spoof a Windows fingerprint regardless of host platform.
        type: string
        const: spoof_windows
  TrackerBlocklist:
    description: "A custom tracker-blocklist source for `browser_open`.\n\nOne of: a remote `url` (fetched+cached at launch), a local `file` path, or\ninline `domains`. Supplying any source implicitly enables blocking."
    oneOf:
      - description: Fetch + cache a newline-delimited host list from this URL.
        type: object
        properties:
          source:
            type: string
            const: url
          url:
            type: string
        additionalProperties: false
        required:
          - source
          - url
      - description: Read a newline-delimited host list from this local file path.
        type: object
        properties:
          path:
            type: string
          source:
            type: string
            const: file
        additionalProperties: false
        required:
          - source
          - path
      - description: Block these hostnames directly.
        type: object
        properties:
          domains:
            type: array
            items:
              type: string
          source:
            type: string
            const: domains
        additionalProperties: false
        required:
          - source
          - domains
