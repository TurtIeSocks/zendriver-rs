---
source: crates/zendriver-mcp/tests/schema_snapshots.rs
expression: "schema_for! (tools::monitor::StartInput)"
---
$schema: "https://json-schema.org/draft/2020-12/schema"
title: StartInput
description: "Input for `browser_monitor_start`."
type: object
properties:
  capture_bodies:
    description: "Fetch each HTTP response body at observe-time and inline it on the\n`http` event (`body` + `body_base64`). One extra CDP round-trip per\nexchange; off by default to keep the buffer light."
    type: boolean
    default: false
  capture_body_max_bytes:
    description: "Maximum bytes of a response body to capture per `http` event when\n`capture_bodies` is set (bounding is against the raw decoded length,\nnever a base64 length). A body larger than this is truncated to that\nmany bytes with `body_truncated: true`; `body_full_bytes` always\nreports the full pre-truncation length. Ignored when `capture_bodies`\nis `false`.\n\nDefaults to `0` (unbounded) — `capture_bodies` keeps its historical\nfull-body behavior when the field is omitted. Set a positive cap\n(`1048576` = 1 MiB is a sensible choice when an agent forwards bodies\ninto its own context) to bound large bodies and keep\n`browser_monitor_read` output manageable."
    type: integer
    format: uint
    default: 0
    minimum: 0
  stream_bodies:
    description: "Opt in to incremental HTTP response body delivery: as each response\nstreams in, `browser_monitor_read` emits `http_data` chunk events\n(`request_id` + base64 `chunk_base64`) ahead of the completed `http`\nevent for the same request. Uses passive CDP\n`Network.streamResourceContent` — no request interception, no\nresponse pausing. Filtered by `url_pattern` like every other event\n(no separate filter). Falls back gracefully to the whole-body\n`capture_bodies` / on-demand path on Chrome versions that don't\nsupport it (roughly pre-124) — the monitor never errors out over\nthis. Off by default: streaming every response is wasted CDP\nround-trips when bodies are small."
    type: boolean
    default: false
  url_pattern:
    description: "Restrict buffered events to those whose URL contains this substring.\nOmit to buffer every observed event."
    type:
      - string
      - "null"
additionalProperties: false
