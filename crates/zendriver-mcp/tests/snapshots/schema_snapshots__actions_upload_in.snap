---
source: crates/zendriver-mcp/tests/schema_snapshots.rs
expression: "schema_for! (tools::actions::UploadInput)"
---
$schema: "https://json-schema.org/draft/2020-12/schema"
title: UploadInput
description: "Input for `browser_upload`."
type: object
properties:
  css:
    type:
      - string
      - "null"
  frame_id:
    type:
      - string
      - "null"
  nth:
    type:
      - integer
      - "null"
    format: uint
    minimum: 0
  paths:
    description: "Absolute paths to attach to the `<input type=\"file\">` element."
    type: array
    items:
      type: string
  role:
    type:
      - string
      - "null"
  role_name:
    type:
      - string
      - "null"
  text:
    type:
      - string
      - "null"
  text_exact:
    type:
      - string
      - "null"
  text_regex:
    type:
      - string
      - "null"
  timeout_ms:
    type: integer
    format: uint64
    default: 5000
    minimum: 0
  visible_only:
    type: boolean
    default: true
  xpath:
    type:
      - string
      - "null"
additionalProperties: false
required:
  - paths
