---
source: crates/zendriver-mcp/tests/schema_snapshots.rs
expression: "schema_for! (tools::stealth::SetStealthProfileOutput)"
---
$schema: "https://json-schema.org/draft/2020-12/schema"
title: SetStealthProfileOutput
description: "Output of `browser_set_stealth_profile`."
type: object
properties:
  active_profile:
    description: The profile that is now configured as the session default.
    $ref: "#/$defs/StealthProfileChoice"
  takes_effect_on_next_open:
    description: "`true` iff a browser is currently open. When `true`, the new\nprofile only applies after `browser_close` + `browser_open`. When\n`false`, the next `browser_open` call will pick it up directly."
    type: boolean
required:
  - active_profile
  - takes_effect_on_next_open
$defs:
  StealthProfileChoice:
    description: "Stealth profile choice carried over the MCP wire.\n\nConcrete `StealthProfile` resolution happens inside the lifecycle\nhandler (it depends on platform detection that only matters at launch\ntime); the wire-level enum stays stable and platform-agnostic."
    oneOf:
      - description: "Defer to `zendriver_stealth::StealthProfile::native()` (auto-detect\nplatform via `sysinfo`)."
        type: string
        const: auto
      - description: "Force native (same as `Auto`, but explicit)."
        type: string
        const: native
      - description: Spoof a macOS fingerprint regardless of host platform.
        type: string
        const: spoof_macos
      - description: Spoof a Linux fingerprint regardless of host platform.
        type: string
        const: spoof_linux
      - description: Spoof a Windows fingerprint regardless of host platform.
        type: string
        const: spoof_windows
